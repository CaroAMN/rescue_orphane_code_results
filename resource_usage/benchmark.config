process {
    // Apply to ALL processes regardless of label or name.
    // These values are set just below physical machine limits:
    //   CPU:    16 logical cores  (i7-10700K, 8 cores x 2 threads)
    //   Memory: 58 GB             (~62GB total, leaving ~4GB for OS + Nextflow)
    //   Time:   24 h              (generous ceiling for longest expected process)
    cpus   = 16
    memory = 58.GB
    time   = 24.h
}
 
// resourceLimits acts as a global ceiling — Nextflow will not allow any
// process to request more than these values even if the process block or
// a label tries to scale beyond them (e.g. via task.attempt multipliers).
// This prevents retry attempts from requesting more than the machine has.
resourceLimits = [
    cpus:   16,
    memory: 58.GB,
    time:   24.h
]